# Copy this file to `.env` and fill in real values. `.env` is gitignored and
# must NEVER be committed.
#
# This file is for LOCAL DEVELOPMENT only. In production (DO App Platform),
# there is no .env file — set these as environment variables in the app's
# dashboard (Settings → Environment Variables), with NODE_ENV=production and
# secrets marked as encrypted.

# development | production
NODE_ENV=development

# Secret used to sign JWTs. Generate a long random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Use a DIFFERENT value in dev and prod. Required in all environments.
SECRET_KEY=

# MongoDB connection string. Use a separate database for dev vs prod.
MONGO_URI=
MONGO_PASSWORD=

# Email (Gmail SMTP by default). Required in production.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=

# Cloudinary image hosting. Required in production.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Foursquare Places API key.
FSQ_KEY=

# OPTIONAL: Sentry error tracking DSN (from sentry.io project settings).
# Leave empty to disable error reporting entirely.
SENTRY_DSN=

# Public base URL of THIS backend.
# Dev: http://localhost:3000   Prod: https://pickupiosbackend.me
BACKEND_URL=http://localhost:3000

# DEV ONLY: your machine's Expo dev-server URL, used to build password-reset
# deep links that open Expo Go. Format: exp://<YOUR_LAN_IP>:8081/--
# Ignored in production (prod uses the pickup2:// scheme automatically).
EXPO_GO_URL=exp://192.168.1.10:8081/--
