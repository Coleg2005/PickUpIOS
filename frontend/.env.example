# Local dev config, read by `npm start` (Expo Go / dev client).
# Copy this file to `.env` (which is gitignored) and adjust.
#
# Production and preview builds do NOT use this file — they get their values
# from the matching profile in eas.json instead.

# The backend this app talks to during local development.
#   - To hit your LOCAL backend from a physical phone, use your machine's LAN
#     IP (NOT localhost, which the phone can't reach): http://192.168.1.10:3000
#   - To develop the app against the hosted backend, use the prod URL:
#     https://pickupiosbackend.me
BACKEND_URL=http://192.168.1.10:3000

# App flavor for local runs. Keep as development so `npm start` builds the
# "PickUp2 (Dev)" flavor with the .dev bundle id.
APP_ENV=development
